generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  firstName               String?
  lastName                String?
  phone                   String?
  isPremium               Boolean                  @default(false)
  role                    UserRole                 @default(DIRECTION)
  clubId                  String?
  club                    Club?                    @relation(fields: [clubId], references: [id])
  teamId                  String?
  team                    Team?                    @relation(fields: [teamId], references: [id])
  managedTeamIds          String[]                 @default([])
  linkedPlayerUserId      String?
  createdAt               DateTime                 @default(now())
  accountInvitesSent      AccountInvite[]          @relation("InviteSender")
  acceptedInvite          AccountInvite?           @relation("InviteAcceptedUser")
  drills                  Drill[]
  plannings               Planning[]
  players                 Player[]
  trainings               Training[]
  plateaus                Plateau[]
  attendance              Attendance[]
  matches                 Match[]
  trainingDrills          TrainingDrill[]
  diagrams                Diagram[]
  trainingRoleAssignments TrainingRoleAssignment[]
}

enum UserRole {
  DIRECTION
  COACH
  PLAYER
  PARENT
}

enum AccountInviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

model Club {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  teams     Team[]
}

model Team {
  id        String   @id @default(cuid())
  name      String
  category  String
  format    String
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  users     User[]
  tactics   Tactic[]

  @@unique([clubId, name])
}

model AccountInvite {
  id                 String              @id @default(cuid())
  token              String              @unique
  email              String
  firstName          String?
  lastName           String?
  phone              String?
  role               UserRole
  status             AccountInviteStatus @default(PENDING)
  clubId             String
  invitedByUserId    String
  teamId             String?
  managedTeamIds     String[]            @default([])
  linkedPlayerId     String?
  linkedPlayerUserId String?
  userId             String?             @unique
  expiresAt          DateTime
  acceptedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  invitedBy User  @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  user      User? @relation("InviteAcceptedUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([clubId, status])
  @@index([email, status])
  @@index([clubId, linkedPlayerId, status])
}

model Planning {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  date      DateTime
  data      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  shares    ShareToken[]

  @@unique([userId, date])
}

model ShareToken {
  id         String    @id @default(cuid())
  token      String    @unique
  planningId String
  planning   Planning  @relation(fields: [planningId], references: [id])
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

// === FOOT DOMAIN ===

model Player {
  id                      String                   @id @default(cuid())
  userId                  String?
  user                    User?                    @relation(fields: [userId], references: [id])
  clubId                  String?
  teamId                  String
  name                    String
  first_name              String?
  last_name               String?
  primary_position        String
  secondary_position      String?
  is_child                Boolean                  @default(false)
  parent_first_name       String?
  parent_last_name        String?
  licence                 String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  scorers                 Scorer[]                 @relation("ScorerPlayer")
  assistedScorers         Scorer[]                 @relation("ScorerAssist")
  Attendance              Attendance[]
  MatchTeamPlayer         MatchTeamPlayer[]
  trainingRoleAssignments TrainingRoleAssignment[]
  email                   String?
  phone                   String?

  @@unique([userId, email])
  @@index([teamId])
  @@index([teamId, last_name, first_name, name])
}

model Training {
  id                      String                   @id @default(cuid())
  userId                  String?
  user                    User?                    @relation(fields: [userId], references: [id])
  clubId                  String?
  teamId                  String
  date                    DateTime
  status                  String                   @default("PLANNED") // <= DOIT être là
  attendance              Attendance[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  TrainingDrill           TrainingDrill[]
  trainingRoleAssignments TrainingRoleAssignment[]

  @@index([teamId, date])
}

model Plateau {
  id          String              @id @default(cuid())
  userId      String?
  user        User?               @relation(fields: [userId], references: [id])
  clubId      String?
  teamId      String
  date        DateTime
  lieu        String
  address     String?
  startTime   String?             @map("start_time") @db.VarChar(5)
  meetingTime String?             @map("meeting_time") @db.VarChar(5)
  matches     Match[]
  attendance  Attendance[]
  shares      PlateauShareToken[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([teamId, date])
}

model PlateauShareToken {
  id        String    @id @default(cuid())
  token     String    @unique
  plateauId String
  plateau   Plateau   @relation(fields: [plateauId], references: [id], onDelete: Cascade)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

model Attendance {
  id           String    @id @default(cuid())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  clubId       String?
  teamId       String?
  session_type String
  session_id   String
  player       Player    @relation(fields: [playerId], references: [id])
  playerId     String
  Training     Training? @relation(fields: [trainingId], references: [id])
  trainingId   String?
  Plateau      Plateau?  @relation(fields: [plateauId], references: [id])
  plateauId    String?

  @@unique([userId, session_type, session_id, playerId])
  @@index([session_type, session_id, teamId])
}

model Match {
  id              String       @id @default(cuid())
  userId          String?
  user            User?        @relation(fields: [userId], references: [id])
  clubId          String?
  teamId          String?
  type            String
  played          Boolean      @default(false)
  status          MatchStatus  @default(PLANNED)
  plateau         Plateau?     @relation(fields: [plateauId], references: [id])
  plateauId       String?
  rotationGameKey String?
  teams           MatchTeam[]
  scorers         Scorer[]
  events          MatchEvent[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  opponentName    String?
  tactic          Json?

  @@index([plateauId, rotationGameKey])
  @@index([plateauId, createdAt])
}

enum MatchStatus {
  PLANNED
  PLAYED
  CANCELLED
}

enum MatchEventType {
  GOAL_FOR
  GOAL_AGAINST
  SUBSTITUTION
}

model MatchEvent {
  id          String         @id @default(cuid())
  match       Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId     String
  minute      Int
  type        MatchEventType
  scorerId    String?
  assistId    String?
  slotId      String?
  inPlayerId  String?
  outPlayerId String?
  createdAt   DateTime       @default(now())

  @@index([matchId, minute, createdAt])
}

model MatchTeam {
  id      String            @id @default(cuid())
  match   Match             @relation(fields: [matchId], references: [id])
  matchId String
  side    String
  players MatchTeamPlayer[]
  score   Int               @default(0)

  @@unique([matchId, side])
}

model Scorer {
  id       String  @id @default(cuid())
  match    Match   @relation(fields: [matchId], references: [id])
  matchId  String
  player   Player  @relation("ScorerPlayer", fields: [playerId], references: [id])
  playerId String
  assist   Player? @relation("ScorerAssist", fields: [assistId], references: [id])
  assistId String?
  side     String

  @@index([matchId])
}

model MatchTeamPlayer {
  id          String    @id @default(cuid())
  matchTeam   MatchTeam @relation(fields: [matchTeamId], references: [id])
  matchTeamId String
  player      Player    @relation(fields: [playerId], references: [id])
  playerId    String
  role        String // 'starter' | 'sub'

  @@unique([matchTeamId, playerId, role])
  @@index([playerId])
}

model TrainingDrill {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  clubId     String?
  teamId     String?
  training   Training @relation(fields: [trainingId], references: [id])
  trainingId String
  drillId    String // id d'un drill du catalogue (seed ou personnalisé)
  order      Int      @default(0)
  duration   Int? // override (minutes) pour cette séance
  notes      String?

  @@index([trainingId])
  @@index([userId, trainingId])
}

model TrainingRoleAssignment {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  clubId     String?
  teamId     String?
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  role       String
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([trainingId, playerId])
  @@index([trainingId])
  @@index([trainingId, role])
  @@index([userId, trainingId])
}

model Drill {
  id          String   @id
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  clubId      String?
  teamId      String
  title       String
  category    String
  duration    Int
  players     String
  description String
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Diagram {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  clubId          String?
  teamId          String?
  title           String
  data            String // JSON string décrivant le dessin
  drillId         String? // id d'un drill du catalogue
  trainingDrillId String? // id d'un exercice rattaché à une séance
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([drillId])
  @@index([trainingDrillId])
  @@index([userId, drillId])
  @@index([userId, trainingDrillId])
}

model Tactic {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  formation String
  points    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([teamId, updatedAt(sort: Desc)])
}
